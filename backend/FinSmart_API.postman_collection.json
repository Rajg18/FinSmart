{
  "info": {
    "name": "FinSmart API",
    "_postman_id": "finsmart-api-v1",
    "description": "Smart Personal Finance & Expense Intelligence System — 32 endpoints across 8 modules.\n\n**Setup:** Run '01 Register' then '02 Login' — the token is saved automatically to {{token}} and used by all other requests.\n\nBase URL: http://localhost:8080/api/v1",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "auth": {
    "type": "bearer",
    "bearer": [{ "key": "token", "value": "{{token}}", "type": "string" }]
  },
  "variable": [
    { "key": "baseUrl", "value": "http://localhost:8080/api/v1", "type": "string" },
    { "key": "token",   "value": "", "type": "string" }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "01 Register",
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"rajganesh\",\n  \"password\": \"password123\",\n  \"name\": \"Rajganesh\",\n  \"email\": \"gbrajganesh@gmail.com\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/register", "host": ["{{baseUrl}}"], "path": ["auth", "register"] }
          }
        },
        {
          "name": "02 Login",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "    pm.collectionVariables.set('token', pm.response.json().token);",
                "    console.log('Token saved:', pm.response.json().token.substring(0, 20) + '...');",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"rajganesh\",\n  \"password\": \"password123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        },
        {
          "name": "03 Login Demo",
          "event": [{
            "listen": "test",
            "script": {
              "exec": [
                "if (pm.response.code === 200) {",
                "    pm.collectionVariables.set('token', pm.response.json().token);",
                "}"
              ],
              "type": "text/javascript"
            }
          }],
          "request": {
            "auth": { "type": "noauth" },
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"username\": \"demo\",\n  \"password\": \"demo123\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/auth/login", "host": ["{{baseUrl}}"], "path": ["auth", "login"] }
          }
        }
      ]
    },
    {
      "name": "Transactions",
      "item": [
        {
          "name": "Create Transaction (DEBIT)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant\": \"Swiggy\",\n  \"amount\": 450.00,\n  \"type\": \"DEBIT\",\n  \"category\": \"FOOD\",\n  \"paymentMethod\": \"UPI\",\n  \"transactionDate\": \"2026-06-15T19:30:00\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "Create Transaction (CREDIT / Salary)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant\": \"HDFC Salary\",\n  \"amount\": 75000.00,\n  \"type\": \"CREDIT\",\n  \"category\": \"INCOME\",\n  \"paymentMethod\": \"Bank Transfer\",\n  \"transactionDate\": \"2026-06-01T09:00:00\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/transactions", "host": ["{{baseUrl}}"], "path": ["transactions"] }
          }
        },
        {
          "name": "List Transactions (paginated)",
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/transactions?page=0&size=10",
              "host": ["{{baseUrl}}"],
              "path": ["transactions"],
              "query": [
                { "key": "page", "value": "0" },
                { "key": "size", "value": "10" },
                { "key": "type", "value": "DEBIT", "disabled": true },
                { "key": "category", "value": "FOOD", "disabled": true }
              ]
            }
          }
        },
        {
          "name": "Get Transaction by ID",
          "request": {
            "method": "GET",
            "url": { "raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"] }
          }
        },
        {
          "name": "Update Transaction",
          "request": {
            "method": "PUT",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"merchant\": \"Swiggy\",\n  \"amount\": 500.00,\n  \"type\": \"DEBIT\",\n  \"category\": \"FOOD\",\n  \"paymentMethod\": \"Credit Card\",\n  \"transactionDate\": \"2026-06-15T19:30:00\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"] }
          }
        },
        {
          "name": "Delete Transaction (soft delete)",
          "request": {
            "method": "DELETE",
            "url": { "raw": "{{baseUrl}}/transactions/1", "host": ["{{baseUrl}}"], "path": ["transactions", "1"] }
          }
        }
      ]
    },
