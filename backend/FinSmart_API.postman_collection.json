          "name": "Add Subscription (Monthly)",
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Netflix\",\n  \"amount\": 649,\n  \"billingCycle\": \"MONTHLY\",\n  \"startDate\": \"2025-01-01\"\n}"
            },
            "url": { "raw": "{{baseUrl}}/subscriptions", "host": ["{{baseUrl}}"], "path": ["subscriptions"] }
